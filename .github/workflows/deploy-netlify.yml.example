name: Deploy to Netlify (Alternative)

# INSTRUCTIONS: To use this workflow instead of GitHub Pages:
# 1. Add NETLIFY_AUTH_TOKEN and NETLIFY_SITE_ID to GitHub Secrets
#    - Go to Settings > Secrets and variables > Actions
#    - Get NETLIFY_AUTH_TOKEN from Netlify (User Settings > Applications > Personal Access Tokens)
#    - Get NETLIFY_SITE_ID from Netlify site settings
# 2. Rename this file from 'deploy-netlify.yml.example' to 'deploy-netlify.yml'
# 3. Remove or disable 'deploy.yml' if using this instead

on:
  push:
    branches:
      - main

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    environment: production

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build project
        run: npm run build

      - name: Deploy to Netlify
        uses: netlify/actions/cli@master
        with:
          args: deploy --dir=dist --prod
        env:
          NETLIFY_AUTH_TOKEN: ${{ secrets.NETLIFY_AUTH_TOKEN }}
          NETLIFY_SITE_ID: ${{ secrets.NETLIFY_SITE_ID }}
